# ================================
# User Data & Shell History
# ================================
.bash_history
.zsh_history
.lesshst
.viminfo
.zcompdump*
.zsh_sessions/

# ================================
# Foundry backups
# ================================
.foundry_backups/
.config.backup/
bin.backup/

# ================================
# Desktop & OS Clutter
# ================================
.DS_Store
.Trash/
Library/**
Downloads/
Documents/
Desktop/
Movies/
Music/
Pictures/
Public/

# ================================
# Sensitive Configs & Secrets
# ================================
.ssh/
.ssh/includes/*.conf
.gnupg/
.mylogin.cnf
.aws/config
.aws/credentials
.vpn-configs/
.bitwarden-ssh-agent.sock
.gitconfig
.gitconfig-centerfield
.saml2aws
.config/hosts/**
*.pem
*.ppk
id_*
known_hosts*

# ================================
# App-Generated Runtime
# ================================
.kube/
.krew/**
.docker/
.parallel/
.tmux-powerline/**
.tmux/plugins/**
.cache/pre-commit/**
Library/Caches/**
Library/Group Containers/**
.config/AWSVPNClient/**
.config/AWS VPN Client/**
.config/yadm/**
.config/configstore/**
Library/CloudStorage/**

# ================================
# Local Dev Only
# ================================
.config/coc/extensions/
.config/coc/memos.json
.config/git/config_local
.config/mysql/
.config/gcloud/**
go/pkg/
code/

# ================================
# Vim Plugin Managers
# ================================
.vim/autoload/plug.vim
.vim/plugged/**
.foundry/tmp/

# ================================
# WSL-Specific (Windows filesystem mounts)
# ================================
/mnt/**

# Zellij reference dump (regeneratable via 'zellij setup --dump-config')
.config/zellij/config.kdl.default-reference

# todo-txt data files (personal tasks, not dotfiles)
.config/todo/todo.txt
.config/todo/done.txt
.config/todo/report.txt

# gcloud: entire state directory (credentials, tokens, config caches)
.config/gcloud/

# AWS credentials and config (sensitive)
.aws/

# Generic cache directory (regenerable, contains transient state)
.cache/

# Local log files (machine-local, regenerable)
logs/

# Neovim runtime data (plugins, lazy, mason, luac cache)
.local/share/nvim/
.local/state/nvim/

# tldr cache
.tldrc/

# Go module cache
go/pkg/

# macOS app containers and sync data (OneDrive, etc.)
Library/

# Language version managers and package installs
.pyenv/
.gem/
.npm/

# ~/.local/share and ~/.local/state are all machine-local runtime data
.local/share/
.local/state/

# Container / VM state
.colima/

# AI / ML model blobs
.ollama/

# Chrome/Brave/etc extension storage
.local/share/brave-extensions/

# Backups (local, regenerable)
backup/

# Claude Code state
.claude/
.claude.json
.claude.json.backup
.claude-worktrees/

# Go-installed binaries
go/bin/

# macOS Applications shortcuts
Applications/

# tmux session logs
tmux-client-*.log

# Python tool binaries (pipx, pip install --user)
.local/bin/
.local/pipx/

# Legacy zsh plugin managers (we use zinit now)
.oh-my-zsh/
.zsh/plugins/
.zsh/completions/

# Legacy terminal tools
.skim/
.tmux-powerline/

# macOS system files
.CFUserTextEncoding
.cups/

# Cloud sync folders
/Google Drive
/OneDrive - Centerfield Media LLC

# Third-party app state (may contain tokens/credentials)
.keeper/
.config/argocd/
.config/gh/

# Terraform release-check cache
.terraform.d/

# Defaults marker
.config/.defaults-set

# Backup/temp files (*.bak covers accidental editor backups)
*.bak
.zsh_history.backup-*
.!*!.zsh_history

# Stray debug/test files
.no_p10k_test.zsh
.p10k.debug.zsh

# Legacy version control leftovers
.gitflow_export
.hgignore_global
.stCommitMsg

# Miscellaneous stray files
.wakeup

# Work investigation scratch (command outputs, terraform plans, kubectl dumps)
work-scratch/
