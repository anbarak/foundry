###################################################################################
# This is a recommended file to store your own customizations and plugin          #
# management. It helps keep your main ~/.zshrc file clean. You can source         #
# this file from your ~/.zshrc to activate the settings within.                   #
###################################################################################

# Auto-commit Brewfile changes using Homebrew hook
brew() {
  command brew "$@"
  if [[ "$1" == "install" || "$1" == "upgrade" || "$1" == "uninstall" ]]; then
    echo "📦 Updating Brewfile..."
    brew bundle dump --file="$HOME/.config/homebrew/Brewfile" --force

    echo "🔍 Checking for Brewfile diff..."
    if ! yadm diff --quiet "$HOME/.config/homebrew/Brewfile"; then
      echo "🚫 Saving staged changes (if any)..."
      STAGED=$(yadm diff --cached --name-only | grep -v 'Brewfile' || true)
      for file in $STAGED; do
        yadm reset HEAD "$file"
      done

      echo "➕ Adding Brewfile..."
      yadm add "$HOME/.config/homebrew/Brewfile"

      echo "✅ Committing Brewfile..."
      yadm commit -m "📦 Updated Brewfile" --no-gpg-sign || echo "⚠️ Commit skipped"

      echo "🚀 Pushing..."
      yadm push || echo "⚠️ Push skipped"

      echo "🔁 Re-staging previous files..."
      for file in $STAGED; do
        yadm add "$file"
      done
    else
      echo "✅ No changes in Brewfile."
    fi
  fi
}

# Colorize man pages (replaces OMZ colored-man-pages plugin)
export LESS_TERMCAP_mb=$'\e[1;32m'     # begin blink
export LESS_TERMCAP_md=$'\e[1;32m'     # begin bold
export LESS_TERMCAP_me=$'\e[0m'        # reset bold/blink
export LESS_TERMCAP_so=$'\e[01;33m'    # begin reverse
export LESS_TERMCAP_se=$'\e[0m'        # reset reverse
export LESS_TERMCAP_us=$'\e[1;4;31m'   # begin underline
export LESS_TERMCAP_ue=$'\e[0m'        # reset underline
export GROFF_NO_SGR=1

export GPG_TTY=$(tty)

# Static fzf init (replaces OMZ fzf plugin — saves ~350ms)
if [[ -f "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh" ]]; then
  source "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh"
  source "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh"
fi

# Zoxide init (replaces autojump — saves ~900ms)
eval "$(zoxide init zsh)"
alias j='z'
alias ji='zi'  # interactive picker with fzf

# ============================================================================
# Module Loading - Base + Platform Overrides
# ============================================================================
ZSH_MODULES="$HOME/.config/zsh/modules"
if [[ -d "$ZSH_MODULES" ]]; then
  # Load base modules (00-99, excluding platform overrides)
  for module in "$ZSH_MODULES"/[0-9][0-9]-*.zsh; do
    # Skip platform-specific files (loaded separately below)
    [[ "$module" =~ -(macos|linux|wsl)\.zsh$ ]] && continue
    source "$module"
  done

  # Load platform-specific overrides AFTER base modules
  if [[ "$FOUNDRY_OS" == "macos" && -f "$ZSH_MODULES/01-coreutils-macos.zsh" ]]; then
    source "$ZSH_MODULES/01-coreutils-macos.zsh"
  elif [[ -f "$ZSH_MODULES/01-coreutils-linux.zsh" ]]; then
    source "$ZSH_MODULES/01-coreutils-linux.zsh"
  fi
fi

# Load persisted default model if available
[[ -f ~/.config/ollama/default-model ]] && export OLLAMA_DEFAULT_MODEL="$(< ~/.config/ollama/default-model)"

# Enable vi keybindings only if not already set

# MySQL autocompletion
mysql() {
  if [[ -z "$MYSQL_AUTOCOMPLETE_SOURCED" ]]; then
    MYSQL_AUTOCOMPLETE_SOURCED=1
    latest_mysql_autocomplete=$(find "/opt/homebrew/Cellar/mysql" -name "mysql_autocomplete" 2>/dev/null | sort | tail -n 1)
    [[ -f "$latest_mysql_autocomplete" ]] && source "$latest_mysql_autocomplete"
  fi
  command mysql "$@"
}

# Environment variables (optional)
# Add environment variables specific to your zsh environment here
# (Consider using separate files for system-wide environment variables)
export CLICOLOR=1
export LSCOLORS=GxFxCxDxBxegedabagaced

# =============================================================================
# Foundry Environment Setup
# =============================================================================
# Loads optional feature flags and environment variables for Foundry dev platform.
# Controlled via ~/.foundry/.foundryrc (tracked in yadm)
export FOUNDRY_HOME="$HOME/.foundry"
[[ -f "$FOUNDRY_HOME/.foundryrc" ]] && source "$FOUNDRY_HOME/.foundryrc"


# Set the terminal title to show the user, hostname, and current directory
function set_terminal_title() {
  case $TERM in
    xterm*|rxvt*)
      # Set the title
      print -Pn "\e]2;%n@%m: %~\a"
      ;;
  esac
}

# Apply default apps via duti on first login or setup only
if [[ ! -f "$HOME/.config/.defaults-set" && -x "$HOME/bin/tools/system/set-defaults.sh" ]]; then
  "$HOME/bin/tools/system/set-defaults.sh"
  touch "$HOME/.config/.defaults-set"
fi

# Call the function before each prompt
precmd_functions+=set_terminal_title


# Docker
export DOCKER_DEFAULT_PLATFORM=linux/amd64

# Go
export GOPATH=$HOME/go
export GOROOT="/opt/homebrew/opt/golang/libexec"

# Python
if [[ ":$PYTHONPATH:" != *":$HOME/code/cf/my/insurance-services-utils/scripts:"* ]]; then
    export PYTHONPATH=$PYTHONPATH:"$HOME/code/cf/my/insurance-services-utils/scripts"
fi

load_cloud_profiles() {
  [[ -f "$HOME/.config/clouds/load_all.sh" ]] && source "$HOME/.config/clouds/load_all.sh" centerfield
}
alias load-clouds='load_cloud_profiles'


# Optimized direnv hook - only runs when directory changes
_direnv_hook_fast() {
  if [[ "$_direnv_prev_dir" != "$PWD" ]]; then
    _direnv_prev_dir="$PWD"
    eval "$(direnv export zsh 2>/dev/null)"
  fi
}
_direnv_prev_dir="$PWD"

precmd_functions=(${precmd_functions:#_direnv_hook})
precmd_functions+=(_direnv_hook_fast)

# Default editors for Git, Yadm, and general shell use
export EDITOR=nvim

# Prevent history dups and blanks
setopt HIST_IGNORE_DUPS       # Don’t record duplicates
setopt HIST_IGNORE_ALL_DUPS   # Remove all previous dupes of a new command
setopt HIST_FIND_NO_DUPS      # Skip dupes in history search
setopt HIST_REDUCE_BLANKS     # Remove extra spaces between words
setopt INTERACTIVE_COMMENTS   # Allow # comments at interactive prompt

# Mmanual refresh
alias aws-refresh='refresh_aws_sso'

# Enable auto-wake on Mondays before the secrets-backup LaunchAgent runs
# CF_ENABLE_BACKUP_WAKE=1 → tells the installer script to program pmset
# CF_BACKUP_WAKE_TIME="09:58:00" → system wake time (2 minutes before 10:00 job)
export CF_ENABLE_BACKUP_WAKE=1
export CF_BACKUP_WAKE_TIME="09:58:00"

# =============================================================================
# Performance Monitoring
# =============================================================================
metrics() {
  echo "=== Zsh Performance Metrics ==="
  echo "Startup time:"
  time zsh -i -c exit
  echo ""
  echo "Immediately loaded plugins: ${#plugins[@]}"
  echo "Functions defined: $(print -l ${(ok)functions} | wc -l)"
  echo "Aliases defined: $(alias | wc -l)"
  echo ""
  echo "Path entries: $(print -l ${(s.:.)PATH} | wc -l)"
  echo "Fpath entries: $(print -l ${fpath} | wc -l)"
  echo ""
  echo "Lazy-loadable commands: aws, gcloud, docker, helm, terraform, kubectl, k, gh, pip, j"
}

# =============================================================================
# Performance Monitoring & History
# =============================================================================
#
# USAGE:
#
#   metrics              Quick interactive snapshot of current shell state.
#                        Shows startup time, plugins, functions, hooks, paths.
#
#   metrics-help         Show this usage documentation.
#
#   metrics-all          Quick comprehensive snapshot (~2s). Runs metrics,
#                        metrics-hooks, and metrics-path in one go. Use this
#                        as your default "show me everything important" command.
#
#   metrics-full         Deep validation suite (~15s). Runs every diagnostic
#                        in the suite — variance, hooks, path, p10k,
#                        plugins, aliases. Use before locking in a baseline
#                        or when investigating an unexplained slowdown.
#
#   metrics-baseline     Save current performance as the "golden" baseline.
#                        Run this once after a tuning session to lock in a
#                        reference point.
#
#   metrics-diff         Compare current shell to baseline. Use anytime you
#                        suspect a regression (added a plugin, things feel
#                        slower, weird lag). Warns if startup is >20% slower.
#
#   metrics-log          Append current run to history file. Run occasionally
#                        to build a time series of shell performance.
#
#   metrics-history [N]  Show the last N runs from the log (default: 20).
#                        Useful for spotting trends over weeks/months.
#
#   metrics-hooks [N]    Time each precmd hook over N iterations (default: 50).
#                        Use this when typing/Enter feels laggy — identifies
#                        which per-prompt hook is the offender.
#
#   metrics-profile      Full zprof workflow in one command. Run twice with
#                        'exec zsh' between calls:
#                          metrics-profile     # enables profiling
#                          exec zsh            # restart shell with zprof loaded
#                          metrics-profile     # captures report, disables
#                          exec zsh            # restart to remove overhead
#                        Saves a timestamped report to ~/.cache/zsh-profile-*.txt
#                        and prints the top 10 slowest functions inline. Use
#                        this when startup feels slow and you need to know why.
#
#   metrics-path         Check PATH health: duplicates, missing directories,
#                        and full PATH listing in order. Run after editing
#                        any PATH-related config.
#
#   metrics-variance [N] Run startup measurement N times (default: 10) and
#                        report min/max/avg/stddev. Use this to detect
#                        whether your performance is consistent or highly
#                        variable across runs. Variance >30% indicates a
#                        systemic issue worth investigating.#
#
#   metrics-aliases      Show alias breakdown — total count, sample listing,
#                        and warnings about aliases that shadow real commands.
#                        Use when you're not sure where an alias came from
#                        or you suspect alias conflicts.
#
#   metrics-p10k         Show Powerlevel10k diagnostics — active segments,
#                        per-render timing, gitstatusd status, and prompt
#                        modes. Use when prompt rendering feels slow or
#                        before adding/removing prompt segments.
#
#   metrics-export       Dump current state as JSON. Pipe to jq or append to
#                        a file for external analysis:
#                          metrics-export | jq .
#                          metrics-export >> ~/metrics-archive.jsonl
#
#   zsh-profile on|off   Low-level toggle for zprof loading. Most of the time
#                        you want 'metrics-profile' instead, which wraps this
#                        with capture and reporting. Use the raw toggle only
#                        if you want to keep profiling on across multiple
#                        shells without auto-capturing.
#
# FILES:
#   ~/.cache/zsh-metrics.log              History log (TSV)
#   ~/.cache/zsh-metrics-baseline         Saved baseline state
#   ~/.cache/zsh-profile-*.txt            Timestamped zprof reports
#   ~/.cache/.zsh-profile-enabled         Flag file (presence enables zprof)
#
# WORKFLOW EXAMPLES:
#
#   Routine check (am I still fast?):
#     metrics-all                        # quick snapshot of everything important
#
#   Validate before locking in a new baseline:
#     metrics-full                       # full diagnostic — variance + all subsystems
#     metrics-baseline                   # only after metrics-full looks clean
#
#   Suspect a regression:
#     metrics-diff                       # how far off baseline are we?
#     metrics-hooks                      # if typing lag, which hook?
#     metrics-profile                    # if startup slow, which function?
#       exec zsh
#       metrics-profile
#       exec zsh
#
#   Investigate specific subsystems:
#     metrics-p10k                       # prompt rendering slow?
#     metrics-aliases                    # alias conflicts or shadowing?
#
#   Track trends over time:
#     metrics-log                        # append current run to history
#     metrics-history 50                 # see last 50 runs
#
# =============================================================================

ZSH_METRICS_LOG="$HOME/.cache/zsh-metrics.log"
ZSH_METRICS_BASELINE="$HOME/.cache/zsh-metrics-baseline"
ZSH_METRICS_SOURCE_FILE="${(%):-%x}"  # captured at source-time for metrics-help

[[ -d "$HOME/.cache" ]] || mkdir -p "$HOME/.cache"

# Internal helper: measure startup time of a fresh interactive shell
# Uses EPOCHREALTIME (zsh built-in) to avoid orphaned subprocesses
# from the `time (...)` subshell pattern
_metrics_startup_time() {
  zmodload zsh/datetime 2>/dev/null

  local times=()
  local i start end
  for i in 1 2 3 4 5; do
    start=$EPOCHREALTIME
    zsh -i -c exit </dev/null >/dev/null 2>&1
    end=$EPOCHREALTIME
    times+=($(awk -v s="$start" -v e="$end" 'BEGIN { printf "%.3f", e - s }'))
  done

  REPLY=$(printf '%s\n' "${times[@]}" | sort -n | head -1)
}

# -----------------------------------------------------------------------------
# metrics: quick interactive performance snapshot
# -----------------------------------------------------------------------------
metrics() {
  _metrics_startup_time
  local startup_time=$REPLY
  local plugin_count=${#plugins[@]}
  local func_count=$(print -l ${(ok)functions} | wc -l | tr -d ' ')
  local func_real=$(print -l ${(ok)functions} | grep -v '^_' | wc -l | tr -d ' ')
  local alias_count=$(alias | wc -l | tr -d ' ')
  local path_count=$(print -l ${(s.:.)PATH} | wc -l | tr -d ' ')
  local fpath_count=$(print -l ${fpath} | wc -l | tr -d ' ')
  local hook_count=${#precmd_functions[@]}

  cat <<EOF
╔══════════════════════════════════════════════════════════════╗
║              Zsh Performance Metrics                         ║
╚══════════════════════════════════════════════════════════════╝
📊 Startup time:        ${startup_time}s
📦 Loaded components:
   Plugins (immediate): ${plugin_count}
   Functions (total):   ${func_count}
   Functions (real):    ${func_real}    ← excludes completion stubs
   Aliases:             ${alias_count}
   Precmd hooks:        ${hook_count}
🔗 Environment:
   PATH entries:        ${path_count}
   FPATH entries:       ${fpath_count}
⏳ Lazy-load commands:  aws, gcloud, docker, helm, terraform, kubectl, k, gh, pip, j, python

💡 Commands:
   metrics-help     show full usage docs
   metrics-all      quick comprehensive snapshot (~2s)  ← NEW
   metrics-full     deep validation suite (~15s)         ← NEW
   metrics-log      log this run to history
   metrics-history  show recent runs
   metrics-baseline save current as baseline
   metrics-diff     compare current to baseline
   metrics-hooks    time each precmd hook (typing lag debug)
   metrics-profile  full zprof workflow (startup lag debug)
   metrics-path     check PATH for duplicates and broken entries
   metrics-variance run startup N times to check consistency
   metrics-aliases  show alias breakdown
   metrics-p10k     show p10k segments and render timing
   metrics-export   dump full metrics as JSON
EOF
}

# -----------------------------------------------------------------------------
# metrics-help: print usage docs by parsing the comment header in this file
# -----------------------------------------------------------------------------
metrics-help() {
  if [[ -f "$ZSH_METRICS_SOURCE_FILE" ]]; then
    sed -n '/^# USAGE:/,/^# =====/p' "$ZSH_METRICS_SOURCE_FILE" | sed 's/^# \?//'
  else
    echo "Source file not found. See ~/.zshrc.local for usage."
  fi
}

# -----------------------------------------------------------------------------
# metrics-log: append current run to history file (TSV format)
# -----------------------------------------------------------------------------
metrics-log() {
  _metrics_startup_time
  local startup=$REPLY
  local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local plugin_count=${#plugins[@]}
  local func_count=$(print -l ${(ok)functions} | wc -l | tr -d ' ')
  local hook_count=${#precmd_functions[@]}

  printf "%s\t%s\t%d\t%d\t%d\n" \
    "$timestamp" "$startup" "$plugin_count" "$func_count" "$hook_count" \
    >> "$ZSH_METRICS_LOG"

  echo "✅ Logged: ${startup}s startup, ${plugin_count} plugins, ${func_count} functions"
}

# -----------------------------------------------------------------------------
# metrics-history: show recent runs in a table
# -----------------------------------------------------------------------------
metrics-history() {
  local n=${1:-20}
  if [[ ! -f "$ZSH_METRICS_LOG" ]]; then
    echo "No history yet. Run 'metrics-log' to start tracking."
    return 1
  fi

  printf "%-22s %10s %8s %10s %6s\n" "Timestamp" "Startup" "Plugins" "Functions" "Hooks"
  printf "%-22s %10s %8s %10s %6s\n" "─────────" "───────" "───────" "─────────" "─────"
  tail -n "$n" "$ZSH_METRICS_LOG" | while IFS=$'\t' read -r ts startup plugins funcs hooks; do
    printf "%-22s %9ss %8d %10d %6d\n" "$ts" "$startup" "$plugins" "$funcs" "$hooks"
  done
}

# -----------------------------------------------------------------------------
# metrics-baseline: save current state as the reference baseline
# -----------------------------------------------------------------------------
metrics-baseline() {
  _metrics_startup_time
  local startup=$REPLY

  cat > "$ZSH_METRICS_BASELINE" <<EOF
startup=$startup
plugins=${#plugins[@]}
functions=$(print -l ${(ok)functions} | wc -l | tr -d ' ')
hooks=${#precmd_functions[@]}
date=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
EOF

  echo "✅ Baseline saved: ${startup}s startup"
  echo "   Run 'metrics-diff' anytime to detect regressions."
}

# -----------------------------------------------------------------------------
# metrics-diff: compare current state to saved baseline
# -----------------------------------------------------------------------------
metrics-diff() {
  if [[ ! -f "$ZSH_METRICS_BASELINE" ]]; then
    echo "❌ No baseline saved. Run 'metrics-baseline' first."
    return 1
  fi

  # Read baseline values into local vars (avoid polluting shell)
  local b_startup b_plugins b_funcs b_hooks b_date
  while IFS='=' read -r key value; do
    case "$key" in
      startup)   b_startup="$value" ;;
      plugins)   b_plugins="$value" ;;
      functions) b_funcs="$value" ;;
      hooks)     b_hooks="$value" ;;
      date)      b_date="$value" ;;
    esac
  done < "$ZSH_METRICS_BASELINE"

  _metrics_startup_time
  local c_startup=$REPLY
  local c_plugins=${#plugins[@]}
  local c_funcs=$(print -l ${(ok)functions} | wc -l | tr -d ' ')
  local c_hooks=${#precmd_functions[@]}

  local delta_startup=$(awk -v c="$c_startup" -v b="$b_startup" 'BEGIN { printf "%+.3f", c - b }')
  local pct=$(awk -v c="$c_startup" -v b="$b_startup" 'BEGIN { printf "%+.1f", ((c - b) / b) * 100 }')

  cat <<EOF
╔══════════════════════════════════════════════════════════════╗
║              Metrics Diff vs Baseline                        ║
╚══════════════════════════════════════════════════════════════╝
Baseline saved: $b_date

                    Baseline       Current       Delta
Startup time:       ${b_startup}s         ${c_startup}s         ${delta_startup}s (${pct}%)
Plugins:            ${b_plugins}              ${c_plugins}              $((c_plugins - b_plugins))
Functions:          ${b_funcs}           ${c_funcs}           $((c_funcs - b_funcs))
Precmd hooks:       ${b_hooks}              ${c_hooks}              $((c_hooks - b_hooks))
EOF

  # Warn on regression (>20% slower)
  local regression=$(awk -v c="$c_startup" -v b="$b_startup" 'BEGIN { print (c > b * 1.20) }')
  if [[ "$regression" == "1" ]]; then
    echo ""
    echo "⚠️  REGRESSION DETECTED: startup is >20% slower than baseline"
    echo "   Run 'metrics-hooks' to identify per-prompt offenders, or"
    echo "   'zsh-profile on && exec zsh && zprof' for startup breakdown."
  fi
}

# -----------------------------------------------------------------------------
# metrics-hooks: time each precmd hook over N iterations
# -----------------------------------------------------------------------------
metrics-hooks() {
  zmodload zsh/datetime 2>/dev/null
  local iterations=${1:-50}
  echo "Timing each precmd hook over $iterations iterations..."
  echo ""
  printf "%-40s %12s %12s\n" "Hook" "Total" "Per-call"
  printf "%-40s %12s %12s\n" "────" "─────" "────────"

  local i
  for hook in $precmd_functions; do
    local start=$EPOCHREALTIME
    for i in {1..$iterations}; do
      $hook 2>/dev/null
    done
    local end=$EPOCHREALTIME
    local total=$(awk -v s="$start" -v e="$end" 'BEGIN { printf "%.3f", e - s }')
    local per_call=$(awk -v t="$total" -v n="$iterations" 'BEGIN { printf "%.2fms", (t / n) * 1000 }')
    printf "%-40s %11ss %12s\n" "$hook" "$total" "$per_call"
  done
}

# -----------------------------------------------------------------------------
# metrics-export: dump everything as JSON for external analysis
# -----------------------------------------------------------------------------
metrics-export() {
  _metrics_startup_time
  local startup=$REPLY

  cat <<EOF
{
  "timestamp": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "host": "$(hostname)",
  "shell_version": "$ZSH_VERSION",
  "startup_seconds": $startup,
  "plugins_immediate": ${#plugins[@]},
  "functions_total": $(print -l ${(ok)functions} | wc -l | tr -d ' '),
  "functions_real": $(print -l ${(ok)functions} | grep -v '^_' | wc -l | tr -d ' '),
  "aliases": $(alias | wc -l | tr -d ' '),
  "path_entries": $(print -l ${(s.:.)PATH} | wc -l | tr -d ' '),
  "fpath_entries": $(print -l ${fpath} | wc -l | tr -d ' '),
  "precmd_hooks": ${#precmd_functions[@]},
  "term": "$TERM"
}
EOF
}

# -----------------------------------------------------------------------------
# zsh-profile: toggle zprof loading for the next shell
# -----------------------------------------------------------------------------
zsh-profile() {
  local flag_file="$HOME/.cache/.zsh-profile-enabled"
  case "$1" in
    on)  touch "$flag_file"; echo "✅ Profiling ENABLED — run 'exec zsh' to apply" ;;
    off) rm -f "$flag_file"; echo "❌ Profiling DISABLED — run 'exec zsh' to apply" ;;
    *)   [[ -f "$flag_file" ]] && echo "Profiling: ON" || echo "Profiling: OFF" ;;
  esac
}

# -----------------------------------------------------------------------------
# metrics-profile: full profiling workflow in one command
#
# Enables zprof, prompts you to exec a new shell, captures the report, then
# disables profiling. Saves the output to ~/.cache/zsh-profile-<timestamp>.txt
# so you can compare runs.
# -----------------------------------------------------------------------------
metrics-profile() {
  local flag_file="$HOME/.cache/.zsh-profile-enabled"
  local report_dir="$HOME/.cache"
  local report_file="$report_dir/zsh-profile-$(date +%Y%m%d-%H%M%S).txt"

  # State 1: profiling not yet enabled — turn it on and instruct user
  if [[ ! -f "$flag_file" ]]; then
    touch "$flag_file"
    cat <<EOF
✅ Profiling ENABLED.

Next steps:
   1. Run 'exec zsh'              (starts a new shell with zprof loaded)
   2. Run 'metrics-profile'       (captures the report and disables profiling)

The shell you're in right now does NOT have zprof loaded — you must
'exec zsh' before the second call will work.
EOF
    return 0
  fi

  # State 2: profiling enabled, but zprof not actually loaded in this shell
  # (this happens if user forgot to 'exec zsh' between calls)
  if ! (( $+functions[zprof] )); then
    echo "⚠️  Profiling flag is set but zprof isn't loaded in this shell."
    echo "   Run 'exec zsh' first, then run 'metrics-profile' again."
    return 1
  fi

  # State 3: zprof is loaded — capture report, then disable profiling
  echo "📊 Capturing zprof report..."
  zprof > "$report_file"

  rm -f "$flag_file"

  echo "✅ Report saved: $report_file"
  echo "❌ Profiling DISABLED — run 'exec zsh' to remove overhead from your shell."
  echo ""
  echo "Top 10 slowest functions:"
  echo "─────────────────────────"
  head -n 13 "$report_file" | tail -n 10
  echo ""
  echo "Full report: less $report_file"
}

# -----------------------------------------------------------------------------
# metrics-aliases: show alias breakdown by source
# -----------------------------------------------------------------------------
metrics-aliases() {
  echo "═══ Alias Breakdown ═══"
  echo ""

  local total=$(alias | wc -l | tr -d ' ')
  echo "Total aliases: $total"
  echo ""

  # Group by likely source based on the alias content
  # OMZ aliases typically come from plugin files; custom from your config
  echo "Sample of defined aliases (first 30):"
  alias | head -30 | sed 's/^/  /'
  echo ""

  if (( total > 30 )); then
    echo "... and $((total - 30)) more. Run 'alias' to see all."
  fi
  echo ""

  echo "💡 To find where an alias is defined:"
  echo "     grep -rn 'alias myalias=' ~/.zshrc ~/.zshrc.local ~/.zshrc.plugins"
}

# -----------------------------------------------------------------------------
# metrics-p10k: show p10k segment information and basic timing
# -----------------------------------------------------------------------------
metrics-p10k() {
  if (( ! $+functions[p10k] )); then
    echo "❌ p10k not loaded in this shell"
    return 1
  fi

  echo "═══ Powerlevel10k Diagnostics ═══"
  echo ""

  echo "Left prompt segments:"
  print -l ${POWERLEVEL9K_LEFT_PROMPT_ELEMENTS} | sed 's/^/  /'
  echo ""

  echo "Right prompt segments:"
  print -l ${POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS} | sed 's/^/  /'
  echo ""

  echo "Prompt render time (50 iterations):"
  local start=$EPOCHREALTIME
  local i
  for i in {1..50}; do
    _p9k_precmd 2>/dev/null
  done
  local end=$EPOCHREALTIME
  local total=$(awk -v s="$start" -v e="$end" 'BEGIN { printf "%.3f", e - s }')
  local per_call=$(awk -v t="$total" 'BEGIN { printf "%.2fms", (t / 50) * 1000 }')
  echo "  Total: ${total}s    Per-render: $per_call"
  echo ""

  echo "Gitstatus daemon status:"
  if (( $+functions[gitstatus_query_p9k_] )); then
    echo "  ✅ gitstatusd is loaded (async git status)"
  else
    echo "  ⚠️  gitstatusd not detected — git segments may be slower"
  fi
  echo ""

  echo "Instant prompt mode: ${POWERLEVEL9K_INSTANT_PROMPT:-not set}"
  echo "Transient prompt:    ${POWERLEVEL9K_TRANSIENT_PROMPT:-not set}"
  echo ""

  echo "💡 To re-time after segment changes:"
  echo "     edit ~/.p10k.zsh, then 'source ~/.p10k.zsh && metrics-p10k'"
}

# -----------------------------------------------------------------------------
# metrics-path: check PATH health (duplicates, count, broken entries)
# -----------------------------------------------------------------------------
metrics-path() {
  echo "═══ PATH Health Check ═══"
  echo ""

  local total=$(print -l ${(s.:.)PATH} | wc -l | tr -d ' ')
  echo "Total entries: $total"
  echo ""

  echo "Duplicates:"
  local dupes=$(print -l ${(s.:.)PATH} | sort | uniq -c | sort -rn | awk '$1 > 1')
  if [[ -z "$dupes" ]]; then
    echo "  ✅ none"
  else
    echo "$dupes" | sed 's/^/  ⚠️  /'
  fi
  echo ""

  echo "Non-existent entries:"
  local missing=0
  for dir in ${(s.:.)PATH}; do
    if [[ ! -d "$dir" ]]; then
      echo "  ⚠️  $dir"
      ((missing++))
    fi
  done
  [[ $missing -eq 0 ]] && echo "  ✅ none (all $total directories exist)"
  echo ""

  echo "Full PATH (in order):"
  print -l ${(s.:.)PATH} | nl -ba | sed 's/^/  /'
}

# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# metrics-variance: run startup measurement multiple times to spot inconsistency
# -----------------------------------------------------------------------------
metrics-variance() {
  local runs=${1:-10}
  echo "═══ Startup Time Variance ($runs runs) ═══"
  echo ""

  local times=()
  for i in {1..$runs}; do
    _metrics_startup_time
    times+=($REPLY)
    printf "  Run %2d: %ss\n" $i $REPLY
  done

  echo ""
  local stats=$(printf '%s\n' "${times[@]}" | awk '
    BEGIN { min=999; max=0; sum=0; n=0 }
    { sum+=$1; n++; if($1<min)min=$1; if($1>max)max=$1; vals[n]=$1 }
    END {
      avg=sum/n
      var=0
      for(i=1;i<=n;i++) var += (vals[i]-avg)^2
      stddev = sqrt(var/n)
      printf "  Min:    %.3fs\n  Max:    %.3fs\n  Avg:    %.3fs\n  StdDev: %.3fs\n  Spread: %.1f%%", min, max, avg, stddev, ((max-min)/avg)*100
    }')
  echo "$stats"
  echo ""

  local spread_pct=$(printf '%s\n' "${times[@]}" | awk '
    BEGIN { min=999; max=0; sum=0; n=0 }
    { sum+=$1; n++; if($1<min)min=$1; if($1>max)max=$1 }
    END { printf "%.0f", ((max-min)/(sum/n))*100 }')

  if (( spread_pct > 30 )); then
    echo "⚠️  High variance (>30%) — your startup time is inconsistent."
  else
    echo "✅ Variance is acceptable (<30%)."
  fi
}

# -----------------------------------------------------------------------------
# metrics-all: quick comprehensive snapshot (~2s)
# Runs the cheap, frequently-needed checks in one go.
# -----------------------------------------------------------------------------
metrics-all() {
  metrics
  echo ""
  metrics-hooks 50
  echo ""
  metrics-path
}

# -----------------------------------------------------------------------------
# metrics-full: deep validation suite (~15s)
# Runs everything, including variance and subsystem checks. Use this before
# locking in a new baseline or when investigating an unexplained slowdown.
# -----------------------------------------------------------------------------
metrics-full() {
  echo "Running full diagnostic suite — this will take ~15 seconds..."
  echo ""

  metrics-variance 10
  echo ""
  metrics
  echo ""
  metrics-hooks 100
  echo ""
  metrics-path
  echo ""
  metrics-p10k
  echo ""
  metrics-aliases
  echo ""

  # Cleanup any leftover timing subprocesses
  pkill -f 'zsh -i -c exit' 2>/dev/null

  echo "═══════════════════════════════════════════════════════════════"
  echo "✅ Full diagnostic complete."
  echo "   If everything looks healthy, run 'metrics-baseline' to lock in."
  echo "═══════════════════════════════════════════════════════════════"
}
alias jt=just
alias lg='lazygit'

